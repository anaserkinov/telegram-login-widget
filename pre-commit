#!/bin/sh

# -------------------------
# Kotlin files
# -------------------------
CHANGED_KOTLIN_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep '\.kts\?$')

if [ -n "$CHANGED_KOTLIN_FILES" ]; then
  echo "🔍 Found changed Kotlin files:"
  echo "$CHANGED_KOTLIN_FILES"

  FILE_LIST_COMMA_SEP=$(echo "$CHANGED_KOTLIN_FILES" | tr '\n' ',')
  echo "🛠  Running ktlintFormat for includes: $FILE_LIST_COMMA_SEP"
  ./gradlew ktlintFormat -Pincludes="$FILE_LIST_COMMA_SEP"

  echo "➕ Adding formatted Kotlin changes to commit..."
  echo "$CHANGED_KOTLIN_FILES" | xargs git add

  echo "🔎 Running ktlintCheck..."
  ./gradlew ktlintCheck -Pincludes="$FILE_LIST_COMMA_SEP"

  if [ $? -ne 0 ]; then
    echo "❌ Ktlint check failed! Please fix the errors and try again."
    exit 1
  fi
else
  echo "ℹ️ No changed Kotlin files to check."
fi

exit 0
